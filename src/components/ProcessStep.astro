---
interface Props {
  number: number;
  title: string;
  description: string;
  placeholderClass?: string;
}

const { number, title, description, placeholderClass = 'placeholder-moss' } = Astro.props;
---

<div class="process-step">
  <div class:list={['step-image', placeholderClass]}>
    <span class="step-number">{String(number).padStart(2, '0')}</span>
  </div>
  <div class="step-content">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</div>

<style>
  .process-step {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .step-image {
    aspect-ratio: 1 / 1;
    border-radius: 6px;
    position: relative;
    overflow: hidden;
  }

  .step-number {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1;
  }

  .step-content h3 {
    font-size: 1.1rem;
    color: var(--forest);
    margin-bottom: 0.3rem;
  }

  .step-content p {
    font-size: 0.88rem;
    color: var(--stone);
    line-height: 1.5;
  }
</style>
