---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About | Website1">
  <Header />
  <main>
    <h1>About</h1>
    <p>
      This is a sample Astro website scaffolded and ready to deploy on
      <strong>GitHub Pages</strong>. It demonstrates how to structure an Astro
      project with layouts, reusable components, and multiple pages.
    </p>

    <h2>Project Structure</h2>
    <pre><code>src/
├── components/
│   ├── Card.astro
│   ├── Footer.astro
│   └── Header.astro
├── layouts/
│   └── Layout.astro
└── pages/
    ├── index.astro
    ├── about.astro
    └── blog/
        └── index.astro</code></pre>

    <h2>Getting Started</h2>
    <p>Run the development server:</p>
    <pre><code>npm run dev</code></pre>
    <p>Build for production:</p>
    <pre><code>npm run build</code></pre>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  pre {
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  code {
    font-family: 'SF Mono', 'Fira Code', monospace;
  }
</style>
