---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Card from '../components/Card.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Home | Website1">
  <Header />
  <main>
    <section class="hero">
      <h1>Welcome to <span class="gradient">Website1</span></h1>
      <p>A modern static site built with Astro and deployed on GitHub Pages.</p>
    </section>

    <section class="cards">
      <Card
        title="Fast by default"
        body="Astro ships zero JavaScript to the browser by default, giving you blazing-fast performance out of the box."
      />
      <Card
        title="Content-focused"
        body="Built for content-rich websites. Bring your own content from anywhere — markdown, CMS, APIs, and more."
      />
      <Card
        title="Easy to deploy"
        body="This site is pre-configured for GitHub Pages. Just push to main and GitHub Actions handles the rest."
        href={`${base}about/`}
      />
    </section>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero {
    text-align: center;
    padding: 6rem 0 4rem;
  }

  .hero h1 {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .gradient {
    background: linear-gradient(135deg, var(--accent-light), #c084fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    color: var(--text-muted);
    font-size: 1.2rem;
    max-width: 520px;
    margin: 0 auto;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    padding-bottom: 4rem;
  }
</style>
