---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CollectionCard from '../components/CollectionCard.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import ProcessStep from '../components/ProcessStep.astro';

const base = import.meta.env.BASE_URL;

const collections = [
  { title: 'One-of-a-Kind Pieces', description: 'Unique preserved moss sculptures and wall art — no two are alike.', href: `${base}gallery/`, placeholderClass: 'placeholder-forest' },
  { title: 'Framed Moss Art', description: 'Living textures preserved in handcrafted frames for your walls.', href: `${base}gallery/`, placeholderClass: 'placeholder-moss' },
  { title: 'Centerpieces', description: 'Natural tablescapes featuring moss, bark, pinecones, and mushrooms.', href: `${base}gallery/`, placeholderClass: 'placeholder-bark' },
  { title: 'Custom Work', description: 'Commission a bespoke piece tailored to your space and vision.', href: `${base}custom/`, placeholderClass: 'placeholder-mushroom' },
];

const galleryItems = [
  { title: 'Preserved Moss Art', image: `${base}images/il_1588xN.6169735697_31xf.webp`, aspectRatio: '4/5' },
  { title: 'Moss Wall Piece', image: `${base}images/il_1588xN.6271646263_eov4.webp`, aspectRatio: '3/4' },
  { title: 'Natural Moss Arrangement', image: `${base}images/il_1588xN.7645959604_enok.webp`, aspectRatio: '4/5' },
  { title: 'Woodland Moss Design', image: `${base}images/il_1588xN.7735679231_q5it.webp`, aspectRatio: '3/4' },
  { title: 'Bark & Moss Piece', image: `${base}images/il_1588xN.7744479968_n87u.webp`, aspectRatio: '4/5' },
  { title: 'Forest Texture Art', image: `${base}images/il_1588xN.7763511073_apbx.webp`, aspectRatio: '3/4' },
];

const processSteps = [
  { number: 1, title: 'Gathering', description: 'Responsibly sourcing moss, bark, pinecones, driftwood, and mushrooms from the forests of British Columbia.', placeholderClass: 'placeholder-forest' },
  { number: 2, title: 'Preserving', description: 'Each element is carefully preserved to maintain its colour, texture, and softness for years to come.', placeholderClass: 'placeholder-moss' },
  { number: 3, title: 'Composing', description: 'Arranging natural textures into balanced, one-of-a-kind compositions inspired by the forest floor.', placeholderClass: 'placeholder-bark' },
  { number: 4, title: 'Finishing', description: 'Framing, sealing, and packaging each piece with care — ready to bring nature into your space.', placeholderClass: 'placeholder-mushroom' },
];
---

<Layout title="AuroraMOSS Designs — Preserved Moss Art">
  <Header />
  <main>

    <!-- Hero -->
    <section class="hero" style={`background-image: url('${base}images/il_1588xN.6169735697_31xf.webp'); background-size: cover; background-position: center;`}>
      <div class="hero-overlay">
        <div class="hero-content">
          <h1>Everlasting moss art for woodland&#8209;inspired spaces</h1>
          <p class="hero-sub">Handmade preserved moss decor using forest textures, bark, mushrooms, pinecones, and natural forms.</p>
          <div class="hero-ctas">
            <a href={`${base}gallery/`} class="btn btn-primary">View Gallery</a>
            <a href={`${base}custom/`} class="btn btn-secondary">Request a Custom Piece</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Artist Statement -->
    <section class="statement">
      <div class="container--narrow">
        <p class="statement-text">
          <em>Handmade in British Columbia using preserved moss, wood, bark, stone&#8209;like textures, and natural forms. Each piece is a small fragment of the forest — designed to live beautifully in your home for years to come.</em>
        </p>
      </div>
    </section>

    <!-- Featured Collections -->
    <section class="collections">
      <div class="container">
        <h2 class="section-title">Collections</h2>
        <p class="section-subtitle">Explore handcrafted pieces across our signature collections</p>
        <div class="collections-grid">
          {collections.map((c) => (
            <CollectionCard
              title={c.title}
              description={c.description}
              href={c.href}
              placeholderClass={c.placeholderClass}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Gallery Preview -->
    <section class="gallery-preview">
      <div class="container">
        <h2 class="section-title">Recent Work</h2>
        <p class="section-subtitle">A selection of preserved moss pieces, wall art, and natural arrangements</p>
        <GalleryGrid items={galleryItems} />
        <div class="gallery-cta">
          <a href={`${base}gallery/`} class="btn btn-outline">View Full Gallery</a>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="process">
      <div class="container">
        <h2 class="section-title">The Process</h2>
        <p class="section-subtitle">From forest floor to your walls — how each piece comes to life</p>
        <div class="process-grid">
          {processSteps.map((step) => (
            <ProcessStep
              number={step.number}
              title={step.title}
              description={step.description}
              placeholderClass={step.placeholderClass}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Custom Orders CTA -->
    <section class="custom-cta">
      <div class="container--narrow custom-cta-inner">
        <h2>Have something in mind?</h2>
        <p>Every space is unique. Commission a custom piece designed specifically for your home, office, or event — crafted from preserved moss and natural materials.</p>
        <a href={`${base}custom/`} class="btn btn-primary">Start a Custom Order</a>
      </div>
    </section>

    <!-- Trust Signals -->
    <section class="trust">
      <div class="container">
        <div class="trust-grid">
          <div class="trust-item">
            <span class="trust-icon">&#9733;</span>
            <strong>5-Star Etsy Reviews</strong>
            <p>Consistently rated by happy customers</p>
          </div>
          <div class="trust-item">
            <span class="trust-icon">&#10003;</span>
            <strong>Handmade in BC</strong>
            <p>Crafted in Vancouver, British Columbia</p>
          </div>
          <div class="trust-item">
            <span class="trust-icon">&#9825;</span>
            <strong>Preserved to Last</strong>
            <p>No watering, no sunlight — beauty that endures</p>
          </div>
          <div class="trust-item">
            <span class="trust-icon">&#9741;</span>
            <strong>Responsibly Sourced</strong>
            <p>Natural materials gathered with care</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* Hero */
  .hero {
    min-height: 85vh;
    display: flex;
    padding: 0;
  }

  .hero-overlay {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to bottom, rgba(30, 30, 27, 0.35) 0%, rgba(31, 58, 45, 0.55) 100%);
    padding: 2rem 1.5rem;
  }

  .hero-content {
    text-align: center;
    max-width: 680px;
  }

  .hero-content h1 {
    color: #FAF8F4;
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.2);
  }

  .hero-sub {
    color: rgba(244, 239, 230, 0.85);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.6;
    margin-bottom: 2rem;
    font-weight: 300;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    border: 1.5px solid transparent;
  }

  .btn-primary {
    background: var(--forest);
    color: var(--birch);
    border-color: var(--forest);
  }

  .btn-primary:hover {
    background: var(--moss);
    border-color: var(--moss);
    color: white;
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.15);
    color: var(--birch);
    border-color: rgba(244, 239, 230, 0.4);
    backdrop-filter: blur(4px);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(244, 239, 230, 0.7);
    color: white;
  }

  .btn-outline {
    background: transparent;
    color: var(--forest);
    border-color: var(--forest);
  }

  .btn-outline:hover {
    background: var(--forest);
    color: var(--birch);
  }

  /* Statement */
  .statement {
    background: var(--bg-alt);
    text-align: center;
  }

  .statement-text {
    font-family: var(--font-heading);
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    line-height: 1.8;
    color: var(--bark);
    font-weight: 400;
  }

  /* Section common */
  .section-title {
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    text-align: center;
    color: var(--stone);
    font-size: 1rem;
    margin-bottom: 3rem;
  }

  /* Collections */
  .collections {
    background: var(--bg);
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .collections-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .collections-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Gallery Preview */
  .gallery-preview {
    background: var(--bg-alt);
  }

  .gallery-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* Process */
  .process {
    background: var(--bg);
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  @media (max-width: 900px) {
    .process-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .process-grid {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin: 0 auto;
    }
  }

  /* Custom CTA */
  .custom-cta {
    background: var(--bg-alt);
  }

  .custom-cta-inner {
    text-align: center;
  }

  .custom-cta-inner h2 {
    margin-bottom: 1rem;
  }

  .custom-cta-inner p {
    color: var(--stone);
    font-size: 1.05rem;
    max-width: 540px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  /* Trust */
  .trust {
    background: var(--bg);
    border-top: 1px solid var(--border);
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .trust-icon {
    font-size: 1.5rem;
    color: var(--moss);
    margin-bottom: 0.3rem;
  }

  .trust-item strong {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--charcoal);
    font-weight: 600;
  }

  .trust-item p {
    font-size: 0.85rem;
    color: var(--stone);
  }

  @media (max-width: 768px) {
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 420px) {
    .trust-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
